# Copy to .env for local dev and build_from_scratch.sh (never commit .env).
# System environment variables take precedence over .env when the app runs (see config/runtime.exs).

# --- build_from_scratch.sh seed (skip setup wizard) ---
HOMELAB_INSTANCE_NAME=Homelab
HOMELAB_BASE_DOMAIN=homelab.local
HOMELAB_OIDC_ISSUER=https://aut.hair
HOMELAB_OIDC_CLIENT_ID=
HOMELAB_OIDC_CLIENT_SECRET=
HOMELAB_ORCHESTRATOR=docker_engine
HOMELAB_GATEWAY=traefik

# Optional: adoption importer reads compose from host homelab appdata
# HOMELAB_APPDATA_BIND=/path/to/homelab/appdata
# HOMELAB_ADOPTION_SOURCE_ROOT=/host/homelab/appdata

# --- Phoenix / runtime (mix phx.server, releases) ---
# SECRET_KEY_BASE=
# DATABASE_URL=ecto://postgres:postgres@localhost:5433/homelab_dev
# PHX_HOST=localhost
