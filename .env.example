# Copy to .env (gitignored) and fill in. build_from_scratch.sh sources this file.
# Values already set in your shell environment take precedence over this file.

# --- OIDC (required for login) ---
# Rotate this secret in your identity provider — the previous value was committed
# to git history and must be considered compromised.
HOMELAB_OIDC_CLIENT_SECRET=

# --- Seed overrides (optional; defaults live in build_from_scratch.sh) ---
# HOMELAB_INSTANCE_NAME=Homelab
# HOMELAB_BASE_DOMAIN=homelab.example.com
# HOMELAB_OIDC_ISSUER=https://id.example.com
# HOMELAB_OIDC_CLIENT_ID=
# HOMELAB_ORCHESTRATOR=docker_engine
# HOMELAB_GATEWAY=traefik

# --- Phoenix endpoint (public URL used to build absolute links/redirects) ---
# Defaults to HOMELAB_BASE_DOMAIN / https / 443 in build_from_scratch.sh.
# PHX_HOST=homelab.example.com
# PHX_SCHEME=https
# PHX_PORT=443

# --- Secrets (optional overrides) ---
# If unset, a stable SECRET_KEY_BASE is generated once and persisted to the
# homelab-iab-secrets volume. Set it explicitly to manage it as a Docker/Swarm secret.
# Generate with: mix phx.gen.secret  (or: openssl rand -base64 48)
# SECRET_KEY_BASE=

# --- Image (optional) ---
# Which published GHCR tag docker-compose.prod.yml runs. Defaults to latest;
# pin a release for reproducible deploys, e.g. v1.2.3.
# HOMELAB_IMAGE_TAG=latest

# --- Resource limits (optional) ---
# HOMELAB_MEMORY_LIMIT=1g
# HOMELAB_CPU_LIMIT=2
